# -----------------------------------------------
# Environment variables for Task Management API
# Copy this file to .env and fill in your values
# -----------------------------------------------

# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/taskmanager_db

# JWT Secret Key — generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Algorithm (HS256 is standard for symmetric signing)
ALGORITHM=HS256

# Access token lifespan in minutes (short-lived for security)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifespan in days (long-lived so users stay logged in)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application metadata
APP_NAME=Task Management API
APP_VERSION=1.0.0
DEBUG=True
